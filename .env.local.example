# DriftGrid Environment Variables
# Copy this to .env.local and fill in values as needed.
# None of these are required for local development.

# ─── Mode ──────────────────────────────────────────────
# Set to 'cloud' to enable cloud storage + database.
# Default is 'local' (filesystem-based, no cloud services needed).
# DRIFTGRID_MODE=local

# ─── Local Mode ────────────────────────────────────────
# Optional: Password-protect the admin view
# DRIFT_PASSWORD=your-password

# ─── Cloud Mode: Supabase ──────────────────────────────
# Required for cloud mode. Get these from your Supabase project settings.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Cloud Mode: Cloudflare R2 ────────────────────────
# Required for cloud mode. Get these from your Cloudflare dashboard.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=driftgrid-files
# R2_PUBLIC_URL=https://files.yourdomain.com

# ─── Cloud Mode: Stripe Billing ───────────────────────
# Required for managed cloud. Not needed for BYO infrastructure.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
# NEXT_PUBLIC_STRIPE_TEAM_PRICE_ID=price_...
