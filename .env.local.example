# DriftGrid Environment Variables
# Copy this to .env.local and fill in values as needed.
# None of these are required for local development.

# Optional: Password-protect the admin view
# DRIFT_PASSWORD=your-password

# Optional: Stripe (for paid cloud tier, not needed for self-hosted)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_STRIPE_PRICE_ID=
# STRIPE_SECRET_KEY=

# Optional: Supabase (for cloud features)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
